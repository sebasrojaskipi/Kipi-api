# ═══════════════════════════════════════════
# KIPI API - Variables de entorno
# ═══════════════════════════════════════════
# En Railway, estas variables se inyectan automáticamente
# si vinculas tu servicio MySQL con Variable References.
# 
# Para desarrollo local, copia este archivo como .env
# y llena los valores desde Railway > MySQL > Variables
# ═══════════════════════════════════════════

MYSQLHOST=tu-host-de-railway
MYSQLPORT=3306
MYSQLDATABASE=railway
MYSQLUSER=root
MYSQLPASSWORD=tu-password

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000
